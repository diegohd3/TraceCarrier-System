@page
@model TraceCarrier.OperatorDummy.Pages.Stations.Step3AssembleCarrierModel
@{
    ViewData["Title"] = "Paso 3 - Crear Carrier con Lista";
}

<h2 class="mb-3">Paso 3: Crear Carrier y Asociar Lista de Unidades</h2>

<form method="post" class="card card-body shadow-sm">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Carrier ID (opcional)</label>
            <input class="form-control" asp-for="Input.CarrierId" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Carrier Status</label>
            <input class="form-control" asp-for="Input.CarrierStatus" />
        </div>
        <div class="col-12">
            <label class="form-label">Unit IDs (separados por coma, salto de linea o punto y coma)</label>
            <textarea class="form-control" asp-for="Input.UnitIdsRaw" rows="5"></textarea>
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-outline-secondary" type="submit" asp-page-handler="GenerateCarrierId">Generar Carrier ID</button>
        <button class="btn btn-primary" type="submit" asp-page-handler="Assemble">Crear Carrier y Asociar</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert @(Model.Success ? "alert-success" : "alert-danger") mt-3">@Model.Message</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ApiResponse))
{
    <pre class="bg-light border rounded p-3 mt-3">@Model.ApiResponse</pre>
}
