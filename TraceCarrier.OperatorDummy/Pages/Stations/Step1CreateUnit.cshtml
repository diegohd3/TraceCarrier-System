@page
@model TraceCarrier.OperatorDummy.Pages.Stations.Step1CreateUnitModel
@{
    ViewData["Title"] = "Paso 1 - Crear Unidad";
}

<h2 class="mb-3">Paso 1: Crear Unidad</h2>

<form method="post" class="card card-body shadow-sm">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Unit ID (opcional)</label>
            <input class="form-control" asp-for="Input.UnitId" />
        </div>
        <div class="col-md-6 d-flex align-items-end">
            <button class="btn btn-outline-secondary" type="submit" asp-page-handler="GenerateId">Generar Unit ID</button>
        </div>
        <div class="col-md-6">
            <label class="form-label">Current Process</label>
            <input class="form-control" asp-for="Input.CurrentProcess" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Status</label>
            <input class="form-control" asp-for="Input.Status" />
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-primary" type="submit" asp-page-handler="Create">Crear Unidad</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert @(Model.Success ? "alert-success" : "alert-danger") mt-3">@Model.Message</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ApiResponse))
{
    <pre class="bg-light border rounded p-3 mt-3">@Model.ApiResponse</pre>
}
