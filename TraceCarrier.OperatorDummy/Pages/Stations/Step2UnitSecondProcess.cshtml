@page
@model TraceCarrier.OperatorDummy.Pages.Stations.Step2UnitSecondProcessModel
@{
    ViewData["Title"] = "Paso 2 - Segundo Proceso Unidad";
}

<h2 class="mb-3">Paso 2: Segundo Proceso de Unidad</h2>

<form method="post" class="card card-body shadow-sm">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Unit ID</label>
            <input class="form-control" asp-for="Input.UnitId" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Process Name</label>
            <input class="form-control" asp-for="Input.ProcessName" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Required Time Seconds</label>
            <input class="form-control" asp-for="Input.RequiredTimeSeconds" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Notes</label>
            <input class="form-control" asp-for="Input.Notes" />
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit" asp-page-handler="Start">Iniciar Proceso</button>
        <button class="btn btn-success" type="submit" asp-page-handler="Complete">Completar Proceso</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert @(Model.Success ? "alert-success" : "alert-danger") mt-3">@Model.Message</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ApiResponse))
{
    <pre class="bg-light border rounded p-3 mt-3">@Model.ApiResponse</pre>
}
